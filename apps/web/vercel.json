{
  "framework": "nextjs",
  "functions": {
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-content?batch=1",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/generate-content?batch=2",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/cron/generate-content?batch=3",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/cron/generate-content?batch=4",
      "schedule": "0 11 * * 4"
    },
    {
      "path": "/api/cron/generate-content?batch=5",
      "schedule": "0 11 * * 5"
    },
    {
      "path": "/api/cron/generate-content?batch=6",
      "schedule": "0 11 * * 6"
    },
    {
      "path": "/api/cron/generate-content?batch=7",
      "schedule": "0 11 * * 0"
    },
    {
      "path": "/api/cron/process-videos",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/publish-content",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/analyze-performance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-calls",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/check-quotas",
      "schedule": "0 7 * * *"
    }
  ]
}
