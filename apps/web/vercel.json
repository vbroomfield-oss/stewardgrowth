{
  "framework": "nextjs",
  "functions": {
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-quotas",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/generate-content",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/process-videos",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/publish-content",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/analyze-performance",
      "schedule": "0 */6 * * *"
    }
  ]
}
