# ===========================================
# STEWARDGROWTH ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Deployment Mode: 'local' | 'internal' | 'public'
# - local: For development (no billing, no analytics)
# - internal: For your own Steward products (founder code required, no billing)
# - public: For external customers (billing enabled)
DEPLOYMENT_MODE=local

# ===========================================
# SUPABASE
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# DATABASE (PostgreSQL via Supabase)
# ===========================================
DATABASE_URL=your_postgresql_connection_string
DIRECT_URL=your_postgresql_direct_connection_string

# ===========================================
# AI PROVIDERS
# ===========================================
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# SOCIAL PLATFORMS (add as you connect each one)
# ===========================================

# Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google (for YouTube and Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Instagram (uses Facebook App credentials)
# INSTAGRAM_APP_ID= (same as FACEBOOK_APP_ID)
# INSTAGRAM_APP_SECRET= (same as FACEBOOK_APP_SECRET)

# Social Platform Scope Modes
# Set to "page" after Meta App Review approval for page-level posting
META_SCOPE_MODE=basic
# Set to "organization" for LinkedIn Company Page posting
LINKEDIN_SCOPE_MODE=personal

# ===========================================
# GOOGLE APIs
# ===========================================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=
GA4_PROPERTY_ID=
GOOGLE_ANALYTICS_API_CREDENTIALS=  # JSON service account credentials (base64 encoded)
GOOGLE_SEARCH_CONSOLE_SITE_URL=  # e.g. https://stewardpro.com

# ===========================================
# PAYMENTS (Stripe)
# ===========================================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ===========================================
# BACKGROUND JOBS (Inngest)
# ===========================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ===========================================
# CRON JOBS
# ===========================================
CRON_SECRET=your_cron_secret

# ===========================================
# INTEGRATIONS
# ===========================================

# StewardRing (Call tracking)
STEWARDRING_WEBHOOK_SECRET=your_stewardring_webhook_secret
TELNYX_API_KEY=

# Shotstack (Video Generation)
SHOTSTACK_API_KEY=

# ElevenLabs (AI Voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# HeyGen (AI Avatar Videos)
HEYGEN_API_KEY=
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

# Founder Code (for internal products)
FOUNDER_CODE=STEWARD-FOUNDER-2024

# ===========================================
# OPTIONAL: MONITORING
# ===========================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
